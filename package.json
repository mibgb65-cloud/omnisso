{
  "name": "omni-sso",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:frontend": "vite build",
    "typecheck:worker": "tsc -p tsconfig.worker.json --noEmit",
    "build": "npm run build:frontend && npm run typecheck:worker",
    "dev": "npm run build:frontend && wrangler dev --local --port 8787",
    "deploy": "npm run build && wrangler deploy",
    "generate:key": "node scripts/generate-private-jwk.mjs"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260606.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wrangler": "^4.20.0"
  }
}
